# Environment variables — copy to `.env` and fill in real values.
# Never commit the real .env file.

# Database (Postgres)
#
# Production on Vercel:
#   1. Project → Storage → Create Database → Postgres (free Hobby tier).
#   2. Vercel auto-sets POSTGRES_PRISMA_URL. Copy that value into a new
#      env var called DATABASE_URL (Project → Settings → Environment
#      Variables → Production).
#   3. Run `npx prisma db push` with DATABASE_URL set locally to push
#      the schema. (Or trigger a redeploy — the build will run
#      `prisma generate` automatically.)
#
# Local dev:
#   - Easiest: `docker run -d --name aisalon-pg -p 5432:5432 \
#       -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=aisalon \
#       postgres:16`
#   - Then use the URL below.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aisalon"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Email brand logo (top-right of every email, ~24px tall). Optional — if not
# set, the default AI Salon mark on Vercel Blob is used. Per-template
# EmailStageTemplate.logoUrl overrides this.
# EMAIL_BRAND_LOGO_URL="https://uojldinyokysycfc.public.blob.vercel-storage.com/brand-assets/1782393632010-jeorqc.png"

# Google OAuth (MassaPro.com Google credentials)
GOOGLE_CLIENT_ID="GOOGLE_CLIENT_ID_REDACTED"
GOOGLE_CLIENT_SECRET="GOOGLE_OAUTH_SECRET_REDACTED"

# Admin email — this user gets ADMIN role on sign-in
ADMIN_EMAIL="eze@massapro.com"

# Public site URL — used for OG metadata, OAuth redirects, and absolute URLs.
# In production on Vercel this should be https://aisalon.massapro.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (SMTP) — required for the email/password sign-up flow.
# Without these set, sign-up still creates the user but cannot email
# the password; the password is logged to the server console instead.
#
# Gmail SMTP example (use an App Password, NOT your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=your-account@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM="AI Salon Tel Aviv <no-reply@massapro.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Vercel deploy token — used by `vercel deploy --prod --yes --token $VERCEL_TOKEN`
# Create at: https://vercel.com/account/tokens (scope: Full Account, Expires: ~6mo)
VERCEL_TOKEN=""
